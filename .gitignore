# Python bytecode
__pycache__/
*.py[cod]

# msys/cygwin crash dumps
*.stackdump

# Claude Code local / harness state
.claude/

# oh-my-claudecode local working state
.omc/

# Runtime HUD state lives in ~/.cache/mmt (outside the repo), but ignore any local copy
.cache/
*.tmp

